<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {% endif %}{{ site.name }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <meta name="theme-color" content="#352879" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/style.css" />
    <script>
      // Apply the saved INVERT (light) preference early, on essay pages only,
      // so there's no flash of the dark theme before the page paints.
      try {
        if (localStorage.getItem("invert") === "1") {
          document.documentElement.classList.add("inverted");
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <div class="boot">
      <pre>
    **** {{ site.name | upper }} 64 BASIC V2 ****

 64K RAM SYSTEM  38911 BASIC BYTES FREE

<span class="ready">READY.</span>
LOAD "{{ (title or "INDEX") | upper }}",8
LIST</pre>
    </div>

    <header class="site-header">
      <nav>
        <a href="/" class="{{ 'active' if page.url == '/' }}">ABOUT ME</a>
        <a href="/essays/" class="{{ 'active' if '/essays/' in page.url }}">ESSAYS</a>
      </nav>
      <button type="button" id="invert-toggle" class="invert-btn">INVERT</button>
    </header>

    <main>
      {{ content | safe }}
    </main>

    {% if page.url == "/" %}
    <div class="raster top" aria-hidden="true"></div>
    <div class="scroller" aria-hidden="true">
      <span><b>TUM DE DUM, TUM DE DUM ... ANOTHER CRAZY RELEASE FROM VIP &#9622;&#9623;&#9612;&#9616; GREETINGS FROM ORLEANDER &#9600;&#9604;&#9600;&#9604; THANKS FOR STOPPING BY &#9617;&#9618;&#9619;&#9618;&#9617; GREETS TO DEMON, SOLO, OMEN, NEWLOCAL OF VIP, MR. WAX AND JEAN FROM FBI CREW, TOMI OF ADT AND ALL THE OTHER CRAZY CONTACTS AROUND THE WORLD... SPECIAL THANKS TO CLAUDE OF ANTHROPIC &#9671;&#9671;&#9670; PRESS RUN/STOP + RESTORE TO CONTINUE &#9622;&#9623;&#9612;&#9616;</b></span>
    </div>
    <div class="raster bottom" aria-hidden="true"></div>
    {% endif %}

    <footer class="site-footer">
      <p><span class="ready">READY.</span><br />
      Copyright (C) 2026 Krisztian Flautner, All Rights Reserved. &mdash; <a class="j-email show" data-e="{{ site.email | b64 }}" href="#">email</a><span class="cursor"></span></p>
    </footer>

    <script>
      // Reassemble email links in the browser so the raw address is never in
      // the page source (defeats naive spam-harvesting bots). The address is
      // stored base64-encoded in data-e; ".show" links also display it.
      (function () {
        document.querySelectorAll("a.j-email").forEach(function (el) {
          var e;
          try { e = atob(el.getAttribute("data-e")); } catch (err) { return; }
          if (!e) return;
          el.setAttribute("href", "mailto:" + e);
          if (el.classList.contains("show")) el.textContent = e;
        });
      })();
    </script>

    {% if site.goatcounter %}
    <script data-goatcounter="https://{{ site.goatcounter }}.goatcounter.com/count"
            async src="//gc.zgo.at/count.js"></script>
    {% endif %}

    <script>
      // INVERT button: toggle the light colour scheme and remember the choice.
      (function () {
        var btn = document.getElementById("invert-toggle");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var on = document.documentElement.classList.toggle("inverted");
          try { localStorage.setItem("invert", on ? "1" : "0"); } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
